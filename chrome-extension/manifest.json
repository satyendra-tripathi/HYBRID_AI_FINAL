{
  "manifest_version": 3,
  "name": "AI-IDS Tab Tracker",
  "version": "1.0",
  "description": "Tracks active tab info for AI-IDS security analysis.",
  "permissions": ["tabs", "activeTab", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",    "https://hybrid-ai-final-1.onrender.com/*",    "https://hybrid-ai-final-1.onrender.com/*"
  ]
}